# Enforce CRLF line endings for all text files
* text=auto eol=crlf

# Explicitly mark these as text files
*.ts text eol=crlf
*.js text eol=crlf
*.mjs text eol=crlf
*.html text eol=crlf
*.css text eol=crlf
*.json text eol=crlf
*.md text eol=crlf

# Denote binary files that should not be modified
*.png binary
*.jpg binary
*.gif binary
*.ico binary
